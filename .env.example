# =============================================================================
# HİBRİT KRİPTO TRADING BOT - API ANAHTARLARI
# =============================================================================
# BU DOSYAYI KOPYALAYIP .env OLARAK KAYDET:
#   cp .env.example .env
# SONRA GERÇEKİ DEĞERLERLE DOLDUR
# 
# ⚠️ GÜVENLİK: .env dosyası ASLA git'e girmez (.gitignore'da)
# =============================================================================

# -----------------------------------------------------------------------------
# BİTGET API (Futures Trading)
# -----------------------------------------------------------------------------
# Binance → Hesabım → API Yönetimi → Yeni API Oluştur
# İzinler: Sadece "Trade" + "Read" (Withdraw KAPALI!)
# IP Whitelist: Mümkünse sadece kendi IP adresin
BINANCE_API_KEY=your_bitget_api_key_here
BINANCE_API_SECRET=your_bitget_api_secret_here
BINANCE_PASSPHRASE=your_bitget_passphrase_here

# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# https://aistudio.google.com/app/apikey adresinden al

# -----------------------------------------------------------------------------
# TELEGRAM BOT (Bildirim Sistemi)
# -----------------------------------------------------------------------------
# @BotFather'dan bot oluştur → token al
# Bot'a mesaj at → https://api.telegram.org/bot<TOKEN>/getUpdates → chat_id bul
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
